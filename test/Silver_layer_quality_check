===========================================
Checking silver.erp_customer_az12
===========================================
*/
--Identify out of range dates
-- Expectation: Birthdays between 1920 - today
SELECT DISTINCT  
cs_birthdate 
FROM silver.erp_customer_az12
WHERE cs_birthdate < '1920-01-01'
OR cs_birthdate > GETDATE()

