/* EDA Exploratory Data Analyics

Script purpose:
This is a exploratory data analysis, in which we understand and collect key values to add to our reports and the ways we can sort or aggregate the data*/


/* Explore tables and columns */
-- Explore all Objects in the Database 
SELECT * FROM INFORMATION_SCHEMA.TABLES

--Explore all Columns in the database
SELECT * FROM INFORMATION_SCHEMA.COLUMNS
WHERE TABLE_NAME = 'dim_customers'

/* Dimensions Exploration*/
--Explore all countries our customers come from
SELECT DISTINCT country FROM gold.dim_customers

--Explore all categories "The major division"
SELECT DISTINCT category_name, subcategory, product_name FROM gold.dim_products
ORDER BY 1,2,3

/*Date explorations*/
--Find date of first and last order 
--How many years of sales are avaliable
SELECT 
MIN(sale_order_date) AS [First order],
MAX (sale_order_date) AS [Last Order],
DATEDIFF(YEAR, MIN(sale_order_date), MAX (sale_order_date) ) AS yearsdiff
FROM gold.fact_sales

--Find the oldest and the youngest customer
SELECT 
DATEDIFF (YEAR, MIN(birthday), GETDATE()) AS Oldest,
DATEDIFF (YEAR, MAX(birthday), GETDATE()) AS Youngest
FROM gold.dim_customers

/* Measures exploration*/
--Find the total sales
SELECT 
SUM (sales_amount) AS total_sales
FROM gold.fact_sales
--Find total sales by product 
SELECT 
SUM (sa.sales_amount) OVER (PARTITION BY sa.product_key) AS total_sales,
pr.product_name
FROM gold.fact_sales sa
LEFT JOIN gold.dim_products pr 
ON sa.product_key = pr.product_key

--Find how many items are sold
SELECT 
SUM(sale_quantity) AS total_quantity 
FROM gold.fact_sales

--Find the average selling price

SELECT 
AVG(sale_price) AS average_price
FROM gold.fact_sales

--Find total number of orders
SELECT 
COUNT(DISTINCT sale_order_number) AS order_count
FROM gold.fact_sales

--Find total number of products
SELECT 
COUNT(product_key) AS product_count
FROM gold.dim_products

SELECT 
COUNT(DISTINCT product_key) AS product_count
FROM gold.dim_products
--Find total number of customers
SELECT 
COUNT(customer_key) AS product_count
FROM gold.dim_customers

--Find total number of customers that has placed an order
SELECT 
COUNT(DISTINCT customer_key) AS product_count
FROM gold.fact_sales

--Generate a report that shows all metricts of the business
SELECT 'Total Sales' AS measure_name, SUM(sales_amount) AS measure_value FROM gold.fact_sales
UNION ALL
SELECT 'Total quantity' AS measure_name , SUM(sale_quantity) AS total_quantity FROM gold.fact_sales
UNION ALL 
SELECT 'Average Price'  AS measure_name, AVG(sale_price) AS average_price FROM gold.fact_sales
UNION ALL 
SELECT 'Total number orders'  AS measure_name,  COUNT(DISTINCT sale_order_number) AS order_count FROM gold.fact_sales
UNION ALL 
SELECT 'Total number of products' AS measure_name, COUNT(DISTINCT product_key) AS product_count FROM gold.dim_products
UNION ALL
SELECT 'Total number of customers' AS measure_name, COUNT(customer_key) AS product_count FROM gold.dim_customers

/* Magnitude analyst */

--Find total customers by countries
SELECT 
country,
COUNT(*)
FROM gold.dim_customers
GROUP BY country

--Find total customers by gender
SELECT 
gender,
COUNT(*)
FROM gold.dim_customers
GROUP BY gender


--Find total products by category
SELECT 
category_name,
COUNT(*) AS total_products
FROM gold.dim_products
GROUP BY category_name

--What is the average cost in each category?
SELECT 
category_name,
AVG(product_cost) AS average_cost
FROM gold.dim_products
GROUP BY category_name
ORDER BY average_cost DESC

--What is the total revenue generated for each category?
SELECT 
pr.category_name,
SUM(fs.sales_amount) - SUM (pr.product_cost) AS Total_revenue
FROM gold.dim_products pr
LEFT JOIN gold.fact_sales fs
ON pr.product_key = fs.product_key
GROUP BY pr.category_name
ORDER BY Total_revenue DESC

--Find total revenue is generated by each customer
SELECT 
fs.customer_key,
cs.first_name,
cs.last_name,
SUM (fs.sales_amount) AS total_revenue
FROM gold.fact_sales fs
LEFT JOIN gold.dim_customers cs
ON fs.customer_key = cs.customer_key
GROUP BY fs.customer_key,
cs.first_name,
cs.last_name
ORDER BY total_revenue DESC


--What is the distribution of sold items across the countries?
SELECT 
cs.country,
SUM (fs.sale_quantity)
FROM gold.fact_sales fs
LEFT JOIN gold.dim_customers cs
ON fs.customer_key = cs.customer_id
GROUP BY country

SELECT * FROM gold.fact_sales

/* Ranking Analyst */

-- TOP 5 best selling products
SELECT TOP (5)
pr.product_name,
SUM(fs.sales_amount) AS Total_revenue
FROM gold.dim_products pr
LEFT JOIN gold.fact_sales fs
ON pr.product_key = fs.product_key
GROUP BY pr.product_name
ORDER BY Total_revenue DESC

--Same using window functions
SELECT 
pr.product_name,
ROW_NUMBER() OVER (ORDER BY SUM(fs.sales_amount) DESC) AS rank_products
FROM gold.dim_products pr
LEFT JOIN gold.fact_sales fs
ON pr.product_key = fs.product_key
GROUP BY pr.product_name


--TOP 5 worst selling products
SELECT TOP (5)
pr.product_name,
SUM(fs.sales_amount) AS Total_revenue
FROM gold.dim_products pr
LEFT JOIN gold.fact_sales fs
ON pr.product_key = fs.product_key
GROUP BY pr.product_name
ORDER BY Total_revenue ASC

--Using window funtions
SELECT 
* 
FROM (
	SELECT 
	pr.product_name,
	ROW_NUMBER() OVER (ORDER BY SUM(fs.sales_amount) ASC) AS rank_products
	FROM gold.dim_products pr
	LEFT JOIN gold.fact_sales fs
	ON pr.product_key = fs.product_key
	GROUP BY pr.product_name)t
WHERE rank_products <= 5
