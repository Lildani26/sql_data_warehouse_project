/* 
===============================================================================
	-Data cleaning and transformation
	-Loading silver layer
===============================================================================
The following script is to load the data from the bronze layer to the silver layer. 
before do that we make sure of the quality of the data.
The data cleaning and transformation we will see on the script are:
	- Trimming
	- Handeling duplicates
	- Handeling missing data / nulls
	- Handeling invalid data
	- Normalization
	- Standarization
	- Data extraction
  - Brief explanation on the data quality issue before work on it
In order to optimaze the silver layer load we do the following:
	- Create stored procedure (EXEC silver.load_silver)
	- Error handeling (try-catch)
	- ETL track time
*/

CREATE OR ALTER PROCEDURE silver.load_silver AS 
BEGIN
	DECLARE @start_time DATETIME , @end_time DATETIME, @start_time_fl DATETIME, @end_time_fl DATETIME; 
		BEGIN TRY
			SET @start_time_fl = GETDATE();
			PRINT '==================================================================';
			PRINT '				Loading silver layer...'							;
			PRINT '==================================================================';


			PRINT '------------------------------------------------------------------';
			PRINT 'Loading crm tables'
			PRINT '------------------------------------------------------------------'

			SET @start_time = GETDATE();
		-- crm_Customer_info table
		PRINT '-Truncating table silver.crm_customer_info'
		TRUNCATE TABLE silver.crm_customer_info;
		PRINT '-Inserting data in table silver.crm_customer_info'
		INSERT INTO silver.crm_customer_info(
			cust_id,
			cust_key,
			cust_firstname,
			cust_lastname,
			cust_marital_status,
			cust_gender,
			cust_create_date)
		SELECT 
			cust_id,
			cust_key,
			TRIM(cust_firstname) AS [Customer First Name], --Trimming for unwanted blank spaces
			TRIM(cust_lastname) AS [Customer Last Name],
			CASE 
					WHEN UPPER (TRIM(cust_material_status)) = 'M' THEN 'Married' --standarization
					WHEN UPPER (TRIM(cust_material_status)) = 'S' THEN 'Single'
				ELSE 'Unknown'
			END AS [Marital status],
			CASE 
					WHEN UPPER (TRIM (cust_gender)) = 'M' THEN 'Male'
					WHEN UPPER (TRIM (cust_gender)) = 'F' THEN 'Female'
				ELSE 'Unknown'
			END AS [Gender],
			cust_create_date
			FROM (
					SELECT 
					*,
					ROW_NUMBER () OVER (PARTITION BY cust_id ORDER BY  cust_create_date) flag --Handeling duplicates
					FROM bronze.crm_customer_info 
					)d
		WHERE flag = 1
		SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'

		/*crm_product_info table
		Column 'product_key':  in the column 'product_key' , we need to separate it on 2 separates columns
		to extract 'cat_id' and 'product_key'
		However the info is together in the same colum so we will use REPLACE and SUBSTRING. 

		Column 'product_line': Normalization 

		Column 'product_end_date': end_date is smaller than the start_date in some cases 
		We will use the LEAD() window function to get the next date on the record of the same product_key
		as the end_date for the data to make sense.

		*/
		SET @start_time = GETDATE();
		PRINT '-Truncating table silver.crm_product_info'
		TRUNCATE TABLE silver.crm_product_info;
		PRINT '-Inserting data in table silver.crm_product_info'
		INSERT INTO silver.crm_product_info
		(
			product_id,
			cat_id,
			product_key,
			product_name,
			product_cost,
			product_line,
			product_start_date ,
			product_end_date
		)
		SELECT 
		product_id,
		REPLACE (SUBSTRING (product_key,1,5), '-', '_') AS  cat_id, --To Join 'erp_product_category'
		SUBSTRING (product_key, 7, LEN(product_key)) AS product_key,-- To join 'crm_sales_details'
		TRIM (product_name) AS product_name,
		COALESCE (product_cost, 0) AS product_cost, --Handeling NULLS
		CASE 
			WHEN product_line = 'M' THEN 'Mountain'
			WHEN product_line = 'R' THEN 'Road'
			WHEN product_line = 'S' THEN 'Other Sales'
			WHEN product_line = 'T' THEN 'Touring'
			ELSE 'N/A'
		 END AS product_line,
		CAST (product_start_date AS DATE) AS product_start_date,
		CAST (LEAD(product_start_date) OVER (PARTITION BY product_key ORDER BY product_start_date)AS DATE)  AS product_end_date
		FROM bronze.crm_product_info
		SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'



		/* crm_sales_details 
		-order_date should always be smaller than ship or due date. 
		-date contains only 8 digits if larger then null value.

		bussiness rule: sale_sales = sale_quantity * sale_price
		sale_price = sale_sale / sale_quantity
		-make sure this condition is met. Also handle nulls, negatives values and 0

		*/
		SET @start_time = GETDATE();
		PRINT '-Truncating table  silver.crm_sales_details'
		TRUNCATE TABLE  silver.crm_sales_details;
		PRINT '-Inserting data in table  silver.crm_sales_details'
		INSERT INTO silver.crm_sales_details
		(
			sale_order_number,
			sale_product_key,
			sale_cust_id,
			sale_order_date,
			sale_shipdate,
			sale_duedate,
			sale_sales,
			sale_quantity,
			sale_price
		)
		SELECT
		sale_order_number, 
		sale_product_key,
		sale_cust_id,
		CASE 
			WHEN sale_order_date = 0 OR LEN(sale_order_date) != 8 THEN NULL --Handeling invalid data
			ELSE CAST (CAST(sale_order_date AS VARCHAR)AS DATE ) 
		END AS sale_order_date,
		CASE 
			WHEN sale_shipdate = 0 OR LEN(sale_shipdate) != 8 THEN NULL
			ELSE CAST (CAST(sale_shipdate AS VARCHAR)AS DATE )
		END AS sale_ship_date,
		CASE 
			WHEN sale_duedate = 0 OR LEN(sale_duedate) != 8 THEN NULL
			ELSE CAST (CAST(sale_duedate AS VARCHAR)AS DATE )
		END AS sale_duedate,
		CASE 
			WHEN sale_sales != (sale_quantity * ABS(sale_price)) OR sale_sales IS NULL OR sale_sales <= 0 THEN (sale_quantity * ABS(sale_price)) --Handeling invalid data
			ELSE sale_sales
		END AS sales,
		sale_quantity,
		CASE 
			WHEN sale_price IS NULL OR sale_price <= 0 THEN sale_sales/COALESCE(sale_quantity, 0)
			ELSE sale_price
		END AS sale_price
		FROM bronze.crm_sales_details
		SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'


		/* erp_customers_az12*/

		SET @start_time = GETDATE();
		PRINT '-Truncating table  silver.erp_customer_az12'
		TRUNCATE TABLE  silver.erp_customer_az12;
		PRINT '-Inserting data in table  silver.erp_customer_az12'
		INSERT INTO silver.erp_customer_az12
		(	cs_id ,
			cs_birthdate ,
			cs_gender)
		SELECT
		CASE 
			WHEN cs_id LIKE 'NAS%' THEN SUBSTRING(cs_id, 4, LEN(cs_id))
			ELSE cs_id
		END AS cs_id,
		CASE 
			WHEN cs_birthdate < '1920-01-01' OR cs_birthdate > GETDATE() THEN NULL --Invalid data (bd too in the past or in the future)
			ELSE cs_birthdate  
		END AS birthday_date,
		CASE 
			WHEN UPPER(TRIM(cs_gender)) IN ('F', 'FEMALE') THEN 'Female'
			WHEN UPPER(TRIM(cs_gender)) IN  ('M', 'MALE') THEN 'Male'
			ELSE 'n/a'
		END AS cs_gender
		FROM bronze.erp_customer_az12
		SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'


		/* erp_location*/
		PRINT '-Truncating table  silver.erp_location'
		TRUNCATE TABLE silver.erp_location;
		PRINT '-Inserting data in table silver.erp_location'
		INSERT INTO silver.erp_location
		(
			cus_id,
			country
		)
		SELECT 
		REPLACE (cus_id, '-', '') AS cus_id, --To connect with 'cust_key'  
		CASE 
			WHEN TRIM(country) = 'DE' THEN 'Germany' --data standarization
			WHEN TRIM(country) IN ('USA', 'US') THEN 'United States'
			WHEN TRIM(country) = '' OR country IS NULL THEN 'n/a'
			ELSE TRIM(country)
		END AS country
		FROM bronze.erp_location
		SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'


		/* erp_product_category */
		--Data quality is good.
		SET @start_time = GETDATE();
		PRINT '-Truncating table silver.erp_product_category'
		TRUNCATE TABLE silver.erp_product_category;
		PRINT '-Inserting data in table silver.erp_product_category'
		 INSERT INTO silver.erp_product_category
		 (
			cat_id,
			cat_name,
			cat_subcategory,
			cat_maintenace
		 )
		 SELECT
 			cat_id,
			cat_name,
			cat_subcategory,
			cat_maintenace
		 FROM bronze.erp_product_category
		 SET @end_time = GETDATE(); 
		PRINT '>>> Load duration: ' + CAST (DATEDIFF (second, @start_time, @end_time) AS VARCHAR) + 'seconds'
		PRINT '----------------------------------------------------------------------------------------------'

		SET @end_time_fl = GETDATE();
		PRINT '=====================================';
		PRINT 'Loading silver layer is completed';
		PRINT '>>> Load duration for the whole batch was : ' + CAST (DATEDIFF (second, @start_time_fl, @end_time_fl) AS VARCHAR) + 'seconds';
		PRINT '=====================================';
		END TRY
		BEGIN CATCH
			PRINT '==========================='
			PRINT 'Error when loading the data'
			PRINT 'Error message:' + ERROR_MESSAGE();
			PRINT 'Error number' + CAST(ERROR_NUMBER() AS NVARCHAR);
			PRINT 'Error number' + CAST(ERROR_STATE() AS NVARCHAR);
			PRINT '==========================='

		END CATCH

	END;

--EXEC silver.load_silver --called store procedure
