--Table from ERP source for product category
IF OBJECT_ID ('silver.erp_product_category', 'U') IS NOT NULL
	DROP TABLE silver.erp_product_category;
CREATE TABLE silver.erp_product_category
(
	cat_id NVARCHAR(50),
	cat_name NVARCHAR(50),
	cat_subcategory NVARCHAR(50),
	cat_maintenace NVARCHAR(50),
	dwh_create_date DATETIME DEFAULT GETDATE()
);
